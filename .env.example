# ── Flask ──────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
FLASK_ENV=development

# ── Supabase ────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# ── 암호화 (API 키 등 민감 설정 암호화) ────────────────
ENCRYPTION_KEY=32자-이상의-랜덤-문자열

# ── AI — 텍스트 (필수) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── AI — 이미지 (선택: 사용하는 것만 설정) ──────────────
# FLUX.2 via fal.ai (기본 이미지 엔진)
FAL_KEY=fal_...

# Ideogram 3.0 (한글 텍스트 포함 썸네일/로고)
IDEOGRAM_API_KEY=...

# DALL-E / GPT Image (대안)
OPENAI_API_KEY=sk-...

# 이미지 엔진 선택: flux | ideogram | dalle (기본값: flux)
IMAGE_PROVIDER=flux

# ── PortOne 결제 ────────────────────────────────────────
PORTONE_API_SECRET=...
PORTONE_STORE_ID=...
PORTONE_CHANNEL_KEY_CARD=...
PORTONE_CHANNEL_KEY_KAKAO=...

# ── Redis (선택 — 없으면 파일시스템 세션) ───────────────
# REDIS_URL=redis://localhost:6379/0

# ── 앱 정보 ────────────────────────────────────────────
APP_NAME=매실 크리에이터
APP_URL=http://localhost:5001
